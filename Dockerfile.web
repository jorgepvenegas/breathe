FROM node:20-slim

# Enable pnpm via corepack
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Copy monorepo files first for better layer caching
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY packages/ ./packages/
COPY apps/web/package.json ./apps/web/package.json

# Install dependencies (monorepo-aware)
RUN pnpm install --frozen-lockfile

# Copy full source
COPY apps/web/ ./apps/web/

# Build the web app and its workspace dependencies
RUN pnpm turbo run build --filter=@breath/web

# Set working directory to the web app
WORKDIR /app/apps/web

# Make env injection script executable
RUN chmod +x inject-env.sh

# Serve the static build with runtime env injection
CMD ["./inject-env.sh"]
