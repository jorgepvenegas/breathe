FROM node:20-slim AS builder

# Enable pnpm via corepack
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Copy monorepo files first for better layer caching
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY packages/ ./packages/
COPY apps/web/package.json ./apps/web/package.json

# Install dependencies (monorepo-aware)
RUN pnpm install --frozen-lockfile

# Copy full source
COPY apps/web/ ./apps/web/

# Build the web app and its workspace dependencies
RUN pnpm turbo run build --filter=@breath/web

# Production stage with Caddy
FROM caddy:2-alpine

WORKDIR /app

# Copy built static files
COPY --from=builder /app/apps/web/dist ./dist

# Copy Caddyfile
COPY apps/web/Caddyfile ./Caddyfile

# Caddy runs on $PORT (set by Railway)
CMD ["caddy", "run", "--config", "Caddyfile", "--adapter", "caddyfile"]
